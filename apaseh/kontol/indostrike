-- Optimasi memory dengan weak tables
local function CleanupCache()
    for k in pairs(RemoteCache) do
        if not ReplicatedStorage:FindFirstChild(k) then
            RemoteCache[k] = nil
        end
    end
end

-- Periodic cleanup setiap 5 menit
task.spawn(function()
    while true do
        task.wait(300)
        CleanupCache()
    end
end)

-- Cleanup function
function Cleanup()
    if FishingConnection then
        FishingConnection:Disconnect()
    end
    if AntiAfkConnection then
        AntiAfkConnection:Disconnect()
    end
    if sellLoop then
        task.cancel(sellLoop)
    end
    Rayfield:Destroy()
end

