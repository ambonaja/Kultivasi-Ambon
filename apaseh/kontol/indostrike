-- Auto Farm Function dengan optimasi
function StartFishing()
    StatusLabel:Set("Status: Running | FPS: " .. currentFPS)
    
    -- Cache remote objects untuk akses lebih cepat
    local LevelSystem = RemoteCache.LevelSystem
    local Fishing = RemoteCache.Fishing
    local BobberShop = RemoteCache.BobberShop
    local FriendLuck = RemoteCache.FriendLuck
    
    if not (LevelSystem and Fishing and BobberShop and FriendLuck) then
        Rayfield:Notify({
            Title = "Error",
            Content = "Remote tidak ditemukan!",
            Duration = 3,
            Image = 4483362458
        })
        return
    end
    
    local LevelSystemToServer = LevelSystem:FindFirstChild("ToServer")
    local FishingToServer = Fishing:FindFirstChild("ToServer")
    local BobberShopToServer = BobberShop:FindFirstChild("ToServer")
    local FriendLuckToServer = FriendLuck:FindFirstChild("ToServer")
    
    if not (LevelSystemToServer and FishingToServer and BobberShopToServer and FriendLuckToServer) then
        Rayfield:Notify({
            Title = "Error",
            Content = "Remote ToServer tidak ditemukan!",
            Duration = 3,
            Image = 4483362458
        })
        return
    end
    
    -- Cache fungsi remote
    local StartAutoFishing = LevelSystemToServer:FindFirstChild("StartAutoFishing")
    local Fishing_RemoteThrow = RemoteCache.Fishing_RemoteThrow
    local GetEquippedBobber = BobberShopToServer:FindFirstChild("GetEquippedBobber")
    local GetStatus = FriendLuckToServer:FindFirstChild("GetStatus")
    local ReelFinished = FishingToServer:FindFirstChild("ReelFinished")
    local AutoFishingCatchReport = LevelSystemToServer:FindFirstChild("AutoFishingCatchReport")
    
    FishingConnection = RunService.Heartbeat:Connect(function()
        if FishingActive then
            task.spawn(function()
                pcall(function()
                    if StartAutoFishing then
                        StartAutoFishing:FireServer()
                    end
                    
                    task.wait(FishingDelay * 0.5)
                    
                    if Fishing_RemoteThrow then
                        local args = {
                            0.8778663449629676,
                            "a7753265-0aff-43f3-ae1c-3326e5f2e2cd"
                        }
                        Fishing_RemoteThrow:FireServer(unpack(args))
                    end
                    
                    task.wait(FishingDelay * 0.5)
                    
                    if GetEquippedBobber then
                        GetEquippedBobber:InvokeServer()
                    end
                    
                    task.wait(FishingDelay * 0.5)
                    
                    if GetStatus then
                        GetStatus:InvokeServer()
                    end
                    
                    task.wait(1)
                    
                    if ReelFinished then
                        local result = _G.FishingResult or "SUCCESS"
                        local args = {
                            {
                                duration = 2.8720628059236333,
                                result = result,
                                insideRatio = 0.8
                            },
                            "a7753265-0aff-43f3-ae1c-3326e5f2e2cd"
                        }
                        ReelFinished:FireServer(unpack(args))
                    end
                    
                    task.wait(FishingDelay * 0.5)
                    
                    if AutoFishingCatchReport then
                        AutoFishingCatchReport:FireServer()
                    end
                end)
            end)
            
            if _G.OptimasiHz and _G.OptimasiHz < 60 then
                task.wait(1/_G.OptimasiHz)
            end
        end
    end)
end

function StopFishing()
    StatusLabel:Set("Status: Stopped | FPS: " .. currentFPS)
    if FishingConnection then
        FishingConnection:Disconnect()
        FishingConnection = nil
    end
end

