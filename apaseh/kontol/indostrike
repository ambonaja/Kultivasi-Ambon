-- Fungsi untuk memulai auto sell
function startAutoSell()
    if sellLoop then 
        task.cancel(sellLoop)
        sellLoop = nil
    end
    
    autoSellEnabled = true
    updateSellStatus()
    print("💰 AUTO SELL DIMULAI (Size: " .. sellSize .. ", Interval: " .. sellInterval .. "s)")
    
    sellLoop = task.spawn(function()
        while autoSellEnabled do
            -- Jeda antar penjualan sesuai interval
            task.wait(sellInterval)
            
            -- Fire remote sell
            local remote = getSellRemote()
            if remote then
                local success, err = pcall(function()
                    remote:FireServer(sellSize)
                    totalSells = totalSells + 1
                    updateSellStatus()
                    
                    -- Notifikasi setiap 5 kali jual
                    if totalSells % 5 == 0 then
                        Rayfield:Notify({
                            Title = "Auto Sell",
                            Content = "Berhasil menjual " .. totalSells .. " kali!",
                            Duration = 2,
                            Image = 4483362458
                        })
                    end
                end)
                
                if not success then
                    warn("❌ Error Auto Sell: " .. tostring(err))
                end
            else
                warn("❌ Remote Sell tidak tersedia, mencoba lagi nanti...")
                -- Coba dapatkan remote lagi
                SellRemote = nil
                getSellRemote()
            end
            
            task.wait(1)
        end
    end)
end

-- Fungsi untuk menghentikan auto sell
function stopAutoSell()
    autoSellEnabled = false
    if sellLoop then
        task.cancel(sellLoop)
        sellLoop = nil
    end
    updateSellStatus()
    print("🛑 AUTO SELL DIHENTIKAN")
end

-- Fungsi untuk mengubah ukuran jual
function setSellSize(newSize)
    if newSize and newSize > 0 then
        sellSize = newSize
        updateSellStatus()
        print("📏 Ukuran jual diubah ke: " .. sellSize)
        return true
    end
    return false
end

